<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/bb_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/bb_key_bg"
            android:padding="16dp"
            android:textColor="@color/bb_accent"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_enable_keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/bb_accent"
            android:text="@string/btn_enable_keyboard"
            android:textAllCaps="false"
            android:textColor="@color/bb_text_primary" />

        <Button
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/bb_key_pressed"
            android:text="@string/btn_set_default"
            android:textAllCaps="false"
            android:textColor="@color/bb_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_appearance"
            android:textColor="@color/bb_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_theme"
            android:textColor="@color/bb_text_secondary" />

        <Spinner
            android:id="@+id/theme_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@color/bb_key_bg"
            android:padding="8dp" />

        <TextView
            android:id="@+id/key_scale_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_key_size"
            android:textColor="@color/bb_text_secondary" />

        <SeekBar
            android:id="@+id/key_scale_seek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="35"
            android:progress="15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_behavior"
            android:textColor="@color/bb_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switch_sound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_sound"
            android:textColor="@color/bb_text_primary" />

        <Switch
            android:id="@+id/switch_learn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_learn"
            android:textColor="@color/bb_text_primary" />

        <Switch
            android:id="@+id/switch_two_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_two_type"
            android:textColor="@color/bb_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_language"
            android:textColor="@color/bb_text_secondary" />

        <Spinner
            android:id="@+id/language_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@color/bb_key_bg"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_dictionary"
            android:textColor="@color/bb_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dictionary_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/bb_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_clear_dictionary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/bb_key_border"
            android:text="@string/btn_clear_dictionary"
            android:textAllCaps="false"
            android:textColor="@color/bb_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/section_test"
            android:textColor="@color/bb_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/demo_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/bb_key_bg"
            android:hint="@string/demo_hint"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences|textMultiLine"
            android:minHeight="100dp"
            android:padding="16dp"
            android:textColor="@color/bb_text_primary"
            android:textColorHint="@color/bb_text_secondary" />
    </LinearLayout>
</ScrollView>
